<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>CodeSugar</RootNamespace>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>    
  </PropertyGroup>  

  <PropertyGroup>
    <PublishAot>true</PublishAot>
    <EnableMicrosoftTestingPlatformExtension>true</EnableMicrosoftTestingPlatformExtension>
  </PropertyGroup>

  <ItemGroup>    
    <PackageReference Include="TUnit" Version="1.57.0" />
    <PackageReference Include="TestAttachments.TUnit" Version="4.0.0-Preview-20260129-1218" />
  </ItemGroup>

  <ItemGroup>    
    <PackageReference Include="Microsoft.Extensions.FileProviders.Abstractions" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.FileProviders.Physical" Version="10.0.9" />
    <PackageReference Include="SharpCompress" Version="0.49.1" />
    <PackageReference Include="Microsoft.IO.RecyclableMemoryStream" Version="3.0.1" />
  </ItemGroup>

  <Choose>
    <When Condition="false">
      <ItemGroup>
        <ProjectReference Include="..\..\src\CodeSugar.IO.Sandbox\CodeSugar.IO.Templates.csproj" />
      </ItemGroup>      
    </When>
    <Otherwise>
      <ItemGroup>
        <ProjectReference Include="..\..\src\CodeSugar.IO.SourceGenerator\CodeSugar.IO.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
      </ItemGroup>
    </Otherwise>    
  </Choose>

</Project>
