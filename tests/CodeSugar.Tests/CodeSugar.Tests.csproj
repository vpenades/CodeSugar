<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>CodeSugar</RootNamespace>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
	</PropertyGroup>

  <PropertyGroup>
    <PublishAot>true</PublishAot>
  </PropertyGroup>

  <PropertyGroup>
    <DefineConstants>$(DefineConstants);CODESUGAR_USECODESUGARNAMESPACE</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.FileProviders.Physical" Version="10.0.9" />
    <PackageReference Include="Microsoft.IO.RecyclableMemoryStream" Version="3.0.1" />
    <PackageReference Include="System.CommandLine" Version="2.0.9" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0" />
  </ItemGroup>  

  <ItemGroup>
    <PackageReference Include="TUnit" Version="1.57.0" />
    <PackageReference Include="TestAttachments.TUnit" Version="4.0.0-Preview-20260129-1218" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\CodeSugar.ICommand\CodeSugar.ICommand.csproj" />    
    <ProjectReference Include="..\..\src\CodeSugar.Sys.Sources\CodeSugar.Sys.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.Sys.Text.Sources\CodeSugar.Sys.Text.csproj" />
  </ItemGroup>

  <Choose>
    <When Condition="false">
      <ItemGroup>
        <ProjectReference Include="..\..\src\CodeSugar.IO.Templates\CodeSugar.IO.Templates.csproj" />
				<ProjectReference Include="..\..\src\CodeSugar.Linq.Templates\CodeSugar.Linq.Templates.csproj" />
				<ProjectReference Include="..\..\src\CodeSugar.Logging.Templates\CodeSugar.Logging.Templates.csproj" />
				<ProjectReference Include="..\..\src\CodeSugar.Serialization.Templates\CodeSugar.Serialization.Templates.csproj" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <ProjectReference Include="..\..\src\CodeSugar.IO.SourceGenerator\CodeSugar.IO.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
				<ProjectReference Include="..\..\src\CodeSugar.Linq.SourceGenerator\CodeSugar.Linq.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
				<ProjectReference Include="..\..\src\CodeSugar.Logging.SourceGenerator\CodeSugar.Logging.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
				<ProjectReference Include="..\..\src\CodeSugar.Serialization.SourceGenerator\CodeSugar.Serialization.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
      </ItemGroup>
    </Otherwise>
  </Choose>

</Project>
