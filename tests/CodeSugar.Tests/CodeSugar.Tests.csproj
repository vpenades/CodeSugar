<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>CodeSugar</RootNamespace>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
	</PropertyGroup>

  <PropertyGroup>
    <PublishAot>true</PublishAot>
  </PropertyGroup>

  <PropertyGroup>
    <DefineConstants>$(DefineConstants);CODESUGAR_USECODESUGARNAMESPACE</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.FileProviders.Physical" Version="10.0.9" />
    <PackageReference Include="Microsoft.IO.RecyclableMemoryStream" Version="3.0.1" />
    <PackageReference Include="System.CommandLine" Version="2.0.9" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0" />
  </ItemGroup>

  <PropertyGroup>
    <!--
    1. Include TUnit ant properties below without removing NUnit
    2. run in terminal: "dotnet format analyzers -_severity info -_diagnostics TUNU0001"
    3. remove these lines and nunit
    -->
    <!--
    <TUnitImplicitUsings>false</TUnitImplicitUsings>
    <TUnitAssertionsImplicitUsings>false</TUnitAssertionsImplicitUsings>
    -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" Version="1.57.0" />
    <PackageReference Include="TestAttachments.TUnit" Version="4.0.0-Preview-20260129-1218" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\CodeSugar.AI\CodeSugar.AI.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.ICommand\CodeSugar.ICommand.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.ImageSharp\CodeSugar.ImageSharp.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.Linq.Sources\CodeSugar.Linq.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.Progress.Log\CodeSugar.Progress.Log.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.Srlzn.Bin.Sources\CodeSugar.Srlzn.Bin.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.Sys.Sources\CodeSugar.Sys.csproj" />
    <ProjectReference Include="..\..\src\CodeSugar.Sys.Text.Sources\CodeSugar.Sys.Text.csproj" />
  </ItemGroup>

  <Choose>
    <When Condition=" 1 == 1 ">
      <ItemGroup>
        <ProjectReference Include="..\..\src\CodeSugar.IO.Sandbox\CodeSugar.IO.Templates.csproj" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <ProjectReference Include="..\..\src\CodeSugar.IO.SourceGenerator\CodeSugar.IO.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
      </ItemGroup>
    </Otherwise>
  </Choose>

</Project>
