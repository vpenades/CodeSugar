	</ItemGroup>

	<ItemGroup>
		<Compile Update="Tensors\ColorTypes.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>ColorTypes.tt</DependentUpon>
		</Compile>
		<Compile Update="Tensors\TensorsBitmapDrawing.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>TensorsBitmapDrawing.tt</DependentUpon>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<None Update="Tensors\ColorTypes.tt">
			<LastGenOutput>ColorTypes.cs</LastGenOutput>
			<Generator>TextTemplatingFileGenerator</Generator>
		</None>
		<None Update="Tensors\TensorsBitmapDrawing.tt">
			<LastGenOutput>TensorsBitmapDrawing.cs</LastGenOutput>
			<Generator>TextTemplatingFileGenerator</Generator>
		</None>
	</ItemGroup>

	<ItemGroup>
		<Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />
