<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>__CODESUGAR_ROOTNAMESPACE__</RootNamespace>
		<VersionPrefix>1.0.0</VersionPrefix>
		<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
	</PropertyGroup>

  <PropertyGroup>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

	<PropertyGroup>
		<IsPackable>false</IsPackable>
		<IsPackableAsSources>false</IsPackableAsSources>
	</PropertyGroup>
	
  <PropertyGroup>
